{
  "$schema": "https://biomejs.dev/schemas/2.5.2/schema.json",
  "files": {
    "includes": [
      "**",
      "!!**/dist",
      "!!**/svg",
      "!!**/test/fixtures",
      "!!**/.venv",
      "!!credits.json",
      "!!crops.json"
    ]
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": { "noExplicitAny": "error" },
      "style": {
        "useConst": "error",
        "noNonNullAssertion": "warn",
        "noDefaultExport": "error"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "assist": {
    "actions": {
      "source": { "organizeImports": "on" }
    }
  },
  "overrides": [
    {
      "includes": ["*.config.ts"],
      "linter": {
        "rules": {
          "style": { "noDefaultExport": "off" }
        }
      }
    }
  ]
}
